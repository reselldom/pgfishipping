# ─── Copy to your droplet: /var/www/pgfishipping/pgfishipping/backend/.env
# ─── Never commit real secrets. Generate JWT_SECRET with: openssl rand -base64 48
#
# Replace EVERY placeholder before starting PM2.

NODE_ENV=production
PORT=4000

# Public URLs (no trailing slash on APP_URL / ADMIN_URL)
APP_URL=https://www.example.com
API_URL=https://api.example.com
ADMIN_URL=https://admin.example.com

# Must match storefront default locale (`pgfishipping/frontend` defaultLocale, e.g. ht).
PUBLIC_WEB_DEFAULT_LOCALE=ht

# Postgres on same droplet (example)
DATABASE_URL=postgresql://pgfi_user:STRONG_PASSWORD@127.0.0.1:5432/pgfishipping?schema=public

REDIS_URL=redis://127.0.0.1:6379

JWT_SECRET=PASTE_AT_LEAST_32_CHAR_RANDOM_SECRET_HERE_USE_OPENSSL
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Comma-separated list — MUST include both Vercel production URLs exactly as the browser uses them
CORS_ORIGINS=https://www.example.com,https://admin.example.com

RESEND_API_KEY=
EMAIL_FROM=PGFI Shipping <noreply@example.com>
EMAIL_REPLY_TO=support@example.com

# Optional: Cloudflare R2 (recommended for production uploads). If empty, files use disk under ./uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeThisToSomethingLongAndRandom

JOBS_ENABLED=true
