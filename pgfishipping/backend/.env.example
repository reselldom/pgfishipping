# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME=PGFI Shipping
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
ADMIN_URL=http://localhost:3001

# ─── Database ────────────────────────────────────────────────────────────────
# Docker compose default:
DATABASE_URL=postgresql://pgfi:pgfi_local_password@localhost:5432/pgfishipping?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=PGFI Shipping <noreply@pgfishipping.com>
EMAIL_REPLY_TO=support@pgfishipping.com
# When RESEND_API_KEY is empty, emails are logged to console (dev mode).

# ─── File Storage (Cloudflare R2) ────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pgfishipping-files
R2_PUBLIC_URL=
# When R2 vars empty, uploads write to ./uploads (dev mode).

# ─── External Tracking ───────────────────────────────────────────────────────
AFTERSHIP_API_KEY=
USPS_USER_ID=

# ─── Firebase (Push Notifications) ───────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── MonCash ─────────────────────────────────────────────────────────────────
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=
MONCASH_MODE=sandbox

# ─── NatCash ─────────────────────────────────────────────────────────────────
NATCASH_MERCHANT_ID=
NATCASH_API_KEY=

# ─── Exchange Rate ───────────────────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=

# ─── Super Admin (used by seed) ──────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@pgfishipping.com
SUPER_ADMIN_PASSWORD=ChangeMe!Now123

# ─── Security ────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Warehouse defaults (used by seed) ───────────────────────────────────────
DEFAULT_US_WAREHOUSE_ADDRESS=8435 NW 68TH ST, MEDLEY, FL 33166
